# Supabase — crea un proyecto en https://supabase.com y copia estos valores
# desde Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo para scripts server-side (sync a Obsidian, seeds). Nunca exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# IA — Fase 1 (uso personal). Genera una API key en https://console.anthropic.com
# Nota: no existe una forma soportada de usar la suscripción de Claude Code/Claude.ai
# dentro de un backend hospedado en la nube (esa auth está pensada para el CLI/apps
# oficiales de Anthropic, no para servicios de terceros). Para esta app, la ruta
# soportada es una API key de pago-por-uso — con Claude Haiku/Sonnet el costo de
# estructurar ideas o generar resúmenes semanales es marginal para uso personal.
ANTHROPIC_API_KEY=

# IA — Fase 2 (multi-usuario). Cuando se abra a otras personas, se puede cambiar
# a OpenRouter sin tocar el código que llama a AIProvider.
OPENROUTER_API_KEY=

# Sync a Obsidian — ruta absoluta a la carpeta del vault (patrón "LLM Wiki":
# raw/ + páginas mantenidas por Claude Code + espejo auto-generado desde Supabase)
OBSIDIAN_VAULT_PATH=C:\Users\57302\Desktop\IA JUAN CAMILO\APP PRODUCTIVIDAD\vault

# Google Calendar — OAuth de solo lectura para que la agenda descuente
# reuniones reales y el panel de capacidad/desempeño sea honesto. Crear en
# https://console.cloud.google.com (habilitar "Google Calendar API", configurar
# la pantalla de consentimiento OAuth en modo "External"/"Testing", y crear
# credenciales OAuth de tipo "Web application"). Authorized redirect URIs
# necesarias: http://localhost:3000/api/google/callback,
# http://localhost:3001/api/google/callback, y
# https://<tu-dominio-de-vercel>/api/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
